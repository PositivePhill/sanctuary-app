# SANCTUARY — Environment Configuration
# Copy to .env and set values. Never commit .env.

# =============================================================================
# REQUIRED
# =============================================================================

# Database (Prisma)
# Local dev: SQLite
# Production: Postgres connection string
DATABASE_URL="file:./dev.db"

# Production Postgres example (uncomment and replace placeholders):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# =============================================================================
# OPTIONAL (reserved for future use; set for production readiness)
# =============================================================================

# Session secret — generate crypto-random string for production
# e.g. openssl rand -hex 32
SESSION_SECRET="change-me-in-production"

# CSRF secret — generate crypto-random string for production
CSRF_SECRET="change-me-in-production"
